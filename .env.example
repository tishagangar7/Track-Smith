# NVIDIA API — get key from https://build.nvidia.com → pick a Nemotron model → View Code
NVIDIA_API_KEY=nvapi-...

# Hackathon Nemotron models (defaults match integrate.api catalog)
NEMOTRON_MODEL_MAIN=nvidia/llama-3.3-nemotron-super-49b-v1.5
NEMOTRON_MODEL_FAST=nvidia/nvidia-nemotron-nano-9b-v2

# Local model (DGX Spark / Qwen) — validates + refines Nemotron's plan.
# If unset, Nemotron output is used directly without refinement.
LOCAL_MODEL_URL=http://100.77.70.20:8000
# LOCAL_MODEL_NAME=qwen   # model name sent in the API request (default: qwen)
# LOCAL_MODEL_TIMEOUT=30  # seconds before giving up and using Nemotron plan as-is

# ── Audio / MusicGen (DGX audio server) ──────────────────────────────────────
# Start server on DGX: bash run_audio_server.sh
AUDIO_SERVER_URL=http://100.77.70.20:8001
# AUDIO_DURATION=8         # seconds of generated audio per continuation

# Optional: skip API for local UI testing
# STUB_MODE=true
